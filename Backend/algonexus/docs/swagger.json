{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/v1/backtest/ohlc/range/": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Retrieves OHLC (Open, High, Low, Close) data for a given symbol and market between the specified start and end times. Supports pagination.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Backtest"
                ],
                "summary": "Get OHLC data for a symbol within a date time range",
                "parameters": [
                    {
                        "type": "string",
                        "example": "2020-06-10T00:00:00Z",
                        "description": "Start time in RFC3339 format",
                        "name": "start_time",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "2020-06-15T00:00:00Z",
                        "description": "End time in RFC3339 format",
                        "name": "end_time",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "SPY",
                        "description": "Symbol to retrieve OHLC data for",
                        "name": "symbol",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "NYSEARCA",
                        "description": "Market for the symbol",
                        "name": "market",
                        "in": "query",
                        "required": true
                    },
                    {
                        "minimum": 1,
                        "type": "integer",
                        "default": 50,
                        "description": "Number of results per page",
                        "name": "page_limit",
                        "in": "query"
                    },
                    {
                        "minimum": 1,
                        "type": "integer",
                        "default": 1,
                        "description": "Page number to retrieve",
                        "name": "page_no",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.OHLCRangeResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid time format or missing required query parameters",
                        "schema": {
                            "$ref": "#/definitions/models.OHLCRangeResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/models.OHLCRangeResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.OHLC": {
            "type": "object",
            "properties": {
                "close": {
                    "type": "number"
                },
                "date_Time": {
                    "type": "string"
                },
                "day": {
                    "type": "integer"
                },
                "high": {
                    "type": "number"
                },
                "low": {
                    "type": "number"
                },
                "market": {
                    "type": "string"
                },
                "month": {
                    "type": "integer"
                },
                "open": {
                    "type": "number"
                },
                "symbol": {
                    "type": "string"
                },
                "volume": {
                    "type": "integer"
                },
                "week": {
                    "type": "integer"
                },
                "weekday": {
                    "type": "integer"
                },
                "year": {
                    "type": "integer"
                }
            }
        },
        "models.OHLCRangeResponse": {
            "type": "object",
            "properties": {
                "next_page_no": {
                    "type": "integer"
                },
                "ohlc_data": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.OHLC"
                    }
                },
                "page_limit": {
                    "type": "integer"
                },
                "page_no": {
                    "type": "integer"
                },
                "status": {
                    "type": "integer"
                },
                "status_description": {
                    "type": "string"
                }
            }
        }
    }
}
