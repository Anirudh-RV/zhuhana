# Same as Dockerfile-local but allows the Go toolchain to auto-upgrade so that
# `air@latest` (which now requires Go >= 1.25) installs on the 1.24 base image.
FROM golang:1.24 AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .

FROM golang:1.24

ENV GOTOOLCHAIN=auto

RUN go install github.com/air-verse/air@latest && \
    apt-get update && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .

EXPOSE 8080
CMD ["air"]
