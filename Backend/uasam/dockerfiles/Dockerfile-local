# Stage 1: Build the Go binary (Optional if using Air in container)
FROM golang:1.24 AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Stage 2: Air + runtime with Go >= 1.24
FROM golang:1.24

# Install Air and Docker CLI
RUN go install github.com/air-verse/air@latest && \
    apt-get update && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
COPY .air.toml .

EXPOSE 8080
CMD ["air"]
