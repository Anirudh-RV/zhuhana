    "paths": {
        "/v1/user/login/verify-otp/": {
            "post": {
                "description": "Verifies the OTP provided by the user and returns an access token upon successful authentication",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Verify OTP during login",
                "parameters": [
                    {
                        "description": "Login Verify OTP Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyOTPRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Login authenticated successfully, access token issued",
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyOTPResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request payload or login error",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpVerifyOTPResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyPasswordResponse"
                        }
                    }
                }
            }
        },
        "/v1/user/login/verify-password/": {
            "post": {
                "description": "Checks if user exists and verifies the submitted password. Sends an OTP if the password verification is successful",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Verify user password during login",
                "parameters": [
                    {
                        "description": "Login Verify Password Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyPasswordRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Password verified successfully, proceed to OTP verification",
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyPasswordResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request payload",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpVerifyOTPResponse"
                        }
                    },
                    "401": {
                        "description": "Login error due to invalid credentials or user not existing",
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyPasswordResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/models.LoginVerifyPasswordResponse"
                        }
                    }
                }
            }
        },
        "/v1/user/sign-up/init/": {
            "post": {
                "description": "Initiates user sign-up by checking if the user exists and sending OTP for verification",
