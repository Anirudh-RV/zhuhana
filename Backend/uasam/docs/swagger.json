                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpVerifyOTPResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request payload",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpVerifyOTPResponse"
                        }
                    },
                    "401": {
                        "description": "Wrong OTP",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpVerifyOTPResponse"
                        }
                    },
                    "500": {
                        "description": "Server Error",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpVerifyOTPResponse"
                        }
                    }
                }
            }
        }
