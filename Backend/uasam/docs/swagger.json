{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/v1/user/sign-up/init/": {
            "post": {
                "description": "Initiates user sign-up by checking if the user exists and sending OTP for verification",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Initialize Sign Up",
                "parameters": [
                    {
                        "description": "Sign Up Init Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OTP verification initiated",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitResponse"
                        }
                    },
                    "400": {
                        "description": "User already exists or invalid payload",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitResponse"
                        }
                    },
                    "500": {
                        "description": "Server error",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.SignUpInitRequest": {
            "type": "object",
            "properties": {
                "emailId": {
                    "type": "string"
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "middleName": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "models.SignUpInitResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "integer"
                },
                "status_description": {
                    "type": "string"
                }
            }
        }
    }
}
