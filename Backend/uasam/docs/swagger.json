                    {
                        "description": "Sign Up Init Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OTP verification initiated",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitResponse"
                        }
                    },
                    "400": {
                        "description": "User already exists or invalid payload",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitResponse"
                        }
                    },
                    "500": {
                        "description": "Server error",
                        "schema": {
                            "$ref": "#/definitions/models.SignUpInitResponse"
                        }
                    }
                }
            }
        },
        "/v1/user/sign-up/verify-otp/": {
            "post": {
                "description": "Verifies the OTP and creates the user account if valid.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "Verify OTP and Sign Up User",
                "parameters": [
                    {
                        "description": "Verify OTP Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
